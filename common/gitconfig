[init]
    defaultBranch = main

[alias]
    d = diff
    s = stash

	l = log --graph --oneline --decorate --abbrev-commit
    lc = rev-list --count HEAD

    r = rebase --interactive --autostash --keep-empty
    ra = rebase --abort
    rs = rebase --skip
    rc = rebase --continue

    a = add
    A = add -A

    f = fetch
    F = fetch --all

    g = clone --recurse-submodules --depth=1 --shallow-submodules
    G = clone --recurse-submodules

    c = commit
    cm = commit -m
    ca = commit --amend --no-edit

    bl = branch -a
    bs = switch
    bo = switch --track
    bn = switch -c
    br = branch -m
    bd = branch -d
    bD = branch -D

    p = pull --rebase
    PUSH = push --force-with-lease
    PUSHH = push --force

